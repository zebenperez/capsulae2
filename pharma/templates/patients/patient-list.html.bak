{% load i18n %}

<div class="small-info p-2">* Sin LOPD en los últimos 15 días</div>
<table class="table table-striped table-hover">
    <thead>
        <tr class="small small">
            <th class="row main-th">
                <div class="col-2"> {% trans 'Historial' %} </div>
                <div class="col-5"> {% trans 'Nombre' %} </div>
                <div class="col-2"> {% trans 'CIP' %} </div>
                <div class="col-1"> {% trans 'Edad' %} </div>
                <div class="col-2"></div>
            </th>
        </tr>
    </thead>
    <tbody>
        {% for item in items %}
            <tr class="small" id="row_{{item.id}}">
                <td class="row">
                    <div class="col-2">
                        {% if item.lopd.all|length == 0 %}*{% endif %}
                        {{ item.n_historial }}
                    </div>
                    <div class="col-5">{{ item.full_name }}</div>
                    <div class="col-2">{{ item.cip }}</div>
                    <div class="col-1">{{ item.age }}</div>
                    <div class="col-2 text-right">
                        {#<a class="btn btn-xs" href="{% url "phases" item.id %}" title="{% trans 'View phases' %}"><i class="fas fa-list"></i></a>#}
                        {%comment%}
                        <a class="btn btn-xs ark" data-url="{% url "patient-form" %}" data-target-modal="common-modal" 
                            data-obj_id="{{item.id}}" title="{% trans 'Edit' %}"><i class="fas fa-edit"></i></a>  
                        {%endcomment%}
                        <a class="btn btn-xs" href="{%url "patient-view" item.id%}" title="{%trans 'View patient'%}"><i class="fas fa-eye"></i></a>
                        <a class="btn btn-sm autoremove" data-model-name="pharma.pacientes" data-obj-id="{{item.id}}" 
                            data-url="{% url "autoremove_obj"%}" data-target="row_{{item.id}}" title="{% trans 'Remove' %}"
                            data-confirm="{% trans "Are you sure to remove this element?" %}"><i class="fas fa-trash"></i></a>
                    </div>
                </td>
            </tr>
        {% endfor %}
    </tbody>
</table>

