 @media screen{
     .page {
         visibility:hidden;
     }
}

@page 
{
    /*size: landscape;*/
    width:93%;
    margin:2mm 1mm 2mm 1mm;
    
}

/* ------------------------------
 *  GENERAL STRUCTURE
 * ----------------------------- */

.page-wrapper{
    margin-top: 10mm;
    margin-left: 10mm;
    margin-right: 10mm;
    border:1px solid red;
}
.page{
    width: 210mm;
    height: 297mm;
    background-color: white;
}


body, body *, a, small{
    color:purple;
    font-family:'Ubuntu';
    font-size:8pt;

}
.frame{
    width:48.8%;
    height: 48%;
    display:inline-block;
    padding: 0.5%;
    vertical-align:top;
    margin-bottom: 1px;
    overflow:hidden;
}
    .frame_table{
    width:48.8%;
    float: left;
    padding: 0.5%;
    vertical-align:top;
    margin-bottom: 1px;
    overflow:hidden;
}

.frame_big{
    width:98%;
    height: 48%;
    display: inline-block;
    padding:0.5%;
}

h4{
    color:#478a00;
    border-bottom: 1px solid silver;
}

li span
{
   display:block;
   margin-left: 1.5em;
   font-style:italic;
}

span.bullet{
    background-color: #478a00;
    display: inline-block;
    width: 0.5em;
    height:0.5em;
    margin-left:0;
    font-style:normal;
    margin-right: 1em;
}

ul {
    list-style: none;
    margin:0px;
    padding:0px;
}

li {
    font-size:9px;
    height:30px;
padding:0px;
}

span.exercises {
    font-size:9px;
}
.label{
    display: inline-block;
    width: 10%;
    margin-right: 0.5em;
    height: 2em;
    padding-left: .3em;
    vertical-align:bottom;
    margin-bottom: -0.4em;
    font-size:9px;
}
.field-large{
    display: inline-block;
    width:85%;
    height: 2.2em;
    margin:0;
    vertical-align: top;
    background-color:#f0f0f0;
    color: black;
    font-size: 9pt;
    padding-left: 1em;
    padding-top:0.5em;
    margin-top: 0.2em;
}

.field-short{
    display : inline-block;
    width: 35.5%;
    height: 1.5em;
    vertical-align:top;
    margin: 0;
    background-color: #f0f0f0;
    font-size: 9pt;
    padding-left: 1em;
    padding-top: 0.5em;
    color:black;

    margin-top: 0.2em;
}
.title-box
{
    padding-top: 3em;
    padding-bottom: 1em;
    text-align:right;
}

.title-box h1
{
    color: #478a00;
    font-size: 16pt;
    font-weight:bolder;
}

.title-box h2{
    color: purple;
    font-size: 20pt;
    font-weight:lighter;
}
.title-right {
    text-align:right;	
}

h1.title-right  {
    color: purple;
    font-size: 14pt;			
}

h2.title-right {
    color:#478a00 !important;
    font-size: 12pt;			

}

.logo_box
{
    display: inline-block;
    width: 40%;
    text-align:right;
    margin-top: ;
    vertical-align:bottom;
    overflow:hidden;
}

#logo{
    display: inline-block;
    margin-left: 20px;
    margin-top: 20px;
    max-width: 2cm;
    max-height: 1.5cm;
    object-fit: contain;
}

table{
    width: 100%;
    border: 0.1em solid #478a00;

    border-collapse:collapse;
}
thead{
    border:1px solid #478a00;
}
th{
    background-color:#478a00;
    color:white;
    font-weight:bolder;
    border-right:0.1em solid white;
}
tr{
    border-bottom: 0.1em solid #478a00;
    height: 1.5m;
}

td{
    text-align: center;
    color:black;
    padding: 0.6em;
    height: 1.5em;
    border-right: 1px solid #478a00;
}
.empty p{
    height:1.4em;
}

.frame.right-border{
    border-right: 0.1em dashed lightgray;
}
.frame.top-border{
    border-top: 0.1em dashed lightgray;
}
canvas
{
    width: 100%!important;
    height: 100%!important;
}

#patient-frame {
position:relative; 
    width:48%;
    display:inline-block;
}

#advices-frame {
    width:48%;
    display:inline-block;
}
#data label {
    height:20px;
    vertical-align:top;
}
#data span.label-b {
    color: #000000 !important;
    font-size:9px;
    height:20px;
}
.patient_personal_data{
    display:inline-block ;
    width: 69%;
}
.patient_qr_code{
    display: inline-block;
    width:30%;
    margin-top: -2em;
}

